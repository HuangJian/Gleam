{
  "name": "@gleam/monkey",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "bun run typecheck && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit --incremental",
    "lint": "oxlint . -c ../.oxlintrc.json",
    "format": "oxfmt . --disable-nested-config -c ../.oxfmtrc.json",
    "check": "bun run typecheck && bun run lint && bun run format && bun test && vite build"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@gleam/shared": "*",
    "dompurify": "^3.4.12",
    "marked": "^18.0.6",
    "preact": "^10.29.7",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.5",
    "@testing-library/preact": "^3.2.4",
    "@types/turndown": "^5.0.6",
    "happy-dom": "^20.10.6",
    "rollup-plugin-external-globals": "^0.13.0",
    "vite": "^8.1.4",
    "vite-plugin-monkey": "^8.0.6"
  }
}
