{
  "name": "gleam",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "shared",
    "backend",
    "monkey"
  ],
  "type": "module",
  "scripts": {
    "dev": "bun run --filter @gleam/monkey dev",
    "build": "bun run --filter @gleam/monkey build",
    "preview": "bun run --filter @gleam/monkey preview",
    "typecheck": "bun run --filter '*' typecheck && bun run typecheck:tools",
    "typecheck:tools": "tsc --noEmit --incremental -p tsconfig.json",
    "test": "bun run --filter '*' test",
    "format": "bun run scripts/format.ts",
    "check": "bun run scripts/check.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "typescript": "^7.0.2"
  }
}
