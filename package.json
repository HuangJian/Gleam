{
  "name": "gleam",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "bun run typecheck && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit --incremental",
    "lint": "oxlint . -c .oxlintrc.json",
    "format": "oxfmt . --disable-nested-config -c .oxfmtrc.json",
    "check": "bun run typecheck && bun run lint && bun run format && bun test && vite build"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "preact": "^10.22.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.8.2",
    "@testing-library/preact": "^3.2.4",
    "@types/bun": "^1.3.14",
    "happy-dom": "^17.0.0",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.72.0",
    "typescript": "^7.0.2",
    "vite": "^5.2.11",
    "vite-plugin-monkey": "^4.0.0"
  }
}
