{
  "name": "gleam-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/main.ts",
    "start": "bun run src/main.ts",
    "build": "tsc --noEmit",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/database/migrate.ts"
  },
  "dependencies": {
    "@pothos/core": "^4.6.0",
    "arktype": "^2.1.20",
    "drizzle-orm": "^0.44.2",
    "graphql": "^16.11.0",
    "graphql-yoga": "^5.13.5"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.4",
    "typescript": "^7.0.2"
  }
}
