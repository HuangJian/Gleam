{
  "plugins": ["typescript", "node", "import"],
  "categories": {
    "correctness": "error",
    "suspicious": "error"
  },
  "env": {
    "node": true
  },
  "ignorePatterns": [
    "dist/**",
    "node_modules/**",
    "src/generated/**",
    "data/**",
    "bun.lock",
    "doc/manifest/**",
    "doc/MANIFEST.md"
  ],
  "rules": {
    "oxc/no-async-endpoint-handlers": "off"
  }
}
